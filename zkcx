<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
  <title>梦角字卡传讯</title>
  <style>
    :root {
      --bg: #0a0a0f;
      --surface: #12121a;
      --surface2: #1a1a26;
      --text: #e0d8d0;
      --text2: #a09888;
      --accent: #c9a87c;
      --border: #2a2a35;
      --radius: 12px;
      --shadow: 0 4px 24px rgba(0,0,0,0.4);
    }
    * { margin:0; padding:0; box-sizing:border-box; }
    body {
      font-family: 'Segoe UI','PingFang SC','Microsoft YaHei',system-ui,sans-serif;
      background: #000; color: var(--text);
      min-height:100vh; display:flex; justify-content:center; align-items:center;
    }
    .app {
      width:100%; max-width:480px; height:100vh; max-height:900px;
      background: var(--surface); border-radius:20px; box-shadow:var(--shadow);
      display:flex; flex-direction:column; overflow:hidden; position:relative;
    }
    .header {
      display:flex; align-items:center; padding:12px 16px;
      border-bottom:1px solid var(--border); background:var(--surface); z-index:10;
      gap:10px;
    }
    .avatar-wrap {
      position: relative; cursor: pointer; flex-shrink:0;
    }
    .avatar {
      width:42px; height:42px; border-radius:50%;
      background:linear-gradient(135deg,#3a2a1a,#5a4a3a);
      display:flex; align-items:center; justify-content:center;
      font-size:20px; overflow:hidden; transition: transform 0.2s;
    }
    .avatar img { width:100%; height:100%; object-fit:cover; }
    .avatar.shake { animation: shake 0.4s ease; }
    @keyframes shake {
      0%,100% { transform: translateX(0); }
      25% { transform: translateX(-4px); }
      50% { transform: translateX(4px); }
      75% { transform: translateX(-2px); }
    }
    .online-dot {
      position:absolute; bottom:0; right:0;
      width:10px; height:10px; background:#4caf50; border-radius:50%;
      border:2px solid var(--surface);
    }
    .info { flex:1; }
    .name { font-size:17px; font-weight:600; cursor:pointer; }
    .status-line {
      display:flex; align-items:center; gap:6px; font-size:12px; color:var(--text2);
    }
    .anniversary-line {
      font-size:11px; color:var(--accent); margin-top:2px;
    }
    .actions { display:flex; gap:6px; }
    .icon-btn {
      width:36px; height:36px; border-radius:50%; border:1px solid var(--border);
      background:var(--surface2); color:var(--text2); display:flex;
      align-items:center; justify-content:center; cursor:pointer; font-size:16px;
      transition: all 0.2s;
    }
    .icon-btn:hover { background:var(--accent); color:#1a1a1a; border-color:var(--accent); }
    .announcement-bar {
      background: var(--surface2); padding:6px 16px; font-size:12px; color: var(--accent);
      text-align: center; border-bottom:1px solid var(--border);
      cursor: pointer; display: flex; justify-content: space-between; align-items: center;
    }
    .chat-area {
      flex:1; overflow-y:auto; padding:16px; display:flex; flex-direction:column; gap:12px;
      scroll-behavior: smooth; background-size: cover; background-position: center;
    }
    .chat-area::-webkit-scrollbar { width:4px; }
    .chat-area::-webkit-scrollbar-thumb { background:var(--border); border-radius:2px; }
    .msg {
      max-width:82%; padding:10px 14px; border-radius:18px; font-size:14px;
      line-height:1.6; position:relative; animation: fadeIn 0.3s ease;
      word-break: break-word;
    }
    @keyframes fadeIn { from { opacity:0; transform:translateY(8px); } to { opacity:1; transform:translateY(0); } }
    .msg.me { align-self:flex-end; background:var(--accent); color:#1a1a1a; border-bottom-right-radius:6px; }
    .msg.other { align-self:flex-start; background:var(--surface2); color:var(--text); border-bottom-left-radius:6px; }
    .msg .time { font-size:10px; color:var(--text2); margin-top:4px; opacity:0.7; }
    .msg.me .time { text-align:right; color:#5a4a3a; }
    .msg img { max-width:180px; border-radius:12px; margin-top:4px; }
    .msg .quote {
      font-size:12px; border-left:3px solid var(--accent); padding-left:8px; margin-bottom:6px;
      opacity:0.7; color:var(--text2);
    }
    .typing-indicator {
      align-self:flex-start; background: var(--surface2); color: var(--text2);
      padding: 8px 16px; border-radius: 18px; font-size: 13px; margin-top:4px;
      display: flex; align-items: center; gap: 4px;
    }
    .typing-dots span {
      display: inline-block; width:6px; height:6px; background: var(--text2);
      border-radius: 50%; animation: typing 1.4s infinite ease-in-out; margin:0 1px;
    }
    .typing-dots span:nth-child(2) { animation-delay: 0.2s; }
    .typing-dots span:nth-child(3) { animation-delay: 0.4s; }
    @keyframes typing { 0%,60%,100% { transform: translateY(0); } 30% { transform: translateY(-4px); } }
    .quote-bar {
      background: var(--surface2); padding:8px 12px; margin:0 16px 8px; border-radius:12px;
      display:flex; align-items:center; justify-content:space-between; font-size:13px;
      border-left:4px solid var(--accent);
    }
    .input-area {
      padding:10px 16px 16px; border-top:1px solid var(--border); display:flex; gap:8px;
      align-items:flex-end; background:var(--surface);
    }
    .input-area textarea {
      flex:1; background:var(--surface2); border:1px solid var(--border);
      border-radius:20px; padding:10px 14px; color:var(--text); font-size:14px;
      resize:none; outline:none; font-family:inherit; max-height:80px; transition:0.2s;
    }
    .input-area textarea:focus { border-color:var(--accent); }
    .send-btn, .img-btn {
      width:42px; height:42px; border-radius:50%; background:var(--accent);
      border:none; color:#1a1a1a; cursor:pointer; font-size:18px;
      display:flex; align-items:center; justify-content:center;
      transition: transform 0.2s, opacity 0.2s; flex-shrink:0;
    }
    .img-btn { background:var(--surface2); color:var(--text2); border:1px solid var(--border); }
    .send-btn:hover, .img-btn:hover { transform:scale(1.05); opacity:0.9; }
    .overlay {
      position:fixed; top:0; left:0; width:100%; height:100%;
      background:rgba(0,0,0,0.85); display:none; align-items:center; justify-content:center;
      z-index:200; flex-direction:column;
    }
    .overlay.active { display:flex; }
    .panel {
      background:var(--surface); border-radius:20px; padding:20px; width:90%; max-width:420px;
      max-height:85vh; overflow-y:auto; box-shadow:var(--shadow);
    }
    .panel h3 { color:var(--accent); margin-bottom:16px; font-size:18px; }
    .setting-row {
      display:flex; align-items:center; justify-content:space-between; margin-bottom:12px;
      flex-wrap:wrap;
    }
    .setting-row label { font-size:14px; }
    .setting-row input, .setting-row select {
      background:var(--surface2); border:1px solid var(--border); border-radius:8px;
      color:var(--text); padding:8px; font-size:14px; outline:none; width:140px;
    }
    .btn {
      padding:8px 20px; border-radius:20px; border:none; cursor:pointer;
      font-size:14px; transition:0.2s; font-family:inherit;
    }
    .btn-primary { background:var(--accent); color:#1a1a1a; }
    .btn-secondary { background:var(--surface2); color:var(--text); border:1px solid var(--border); }
    .btn-primary:hover { opacity:0.9; }
    .btn-secondary:hover { border-color:var(--accent); }
    .tabs { display:flex; gap:8px; margin-bottom:16px; flex-wrap:wrap; }
    .tab-btn {
      padding:6px 14px; border-radius:20px; background:var(--surface2); color:var(--text2); border:1px solid var(--border);
      font-size:13px; cursor:pointer;
    }
    .tab-btn.active { background:var(--accent); color:#1a1a1a; }
    .list-item {
      display:flex; align-items:center; justify-content:space-between; padding:8px 0;
      border-bottom:1px solid var(--border);
    }
    .list-item span { flex:1; font-size:14px; }
    .small-btn {
      background:var(--surface2); border:1px solid var(--border); color:var(--text2);
      border-radius:6px; padding:4px 8px; font-size:12px; cursor:pointer; margin-left:4px;
    }
    .small-btn.danger { color:#e53935; }
    .emoji-grid { display:flex; flex-wrap:wrap; gap:8px; }
    .emoji-item {
      width:50px; height:50px; border-radius:10px; overflow:hidden; cursor:pointer;
      border:2px solid transparent; position:relative;
    }
    .emoji-item:hover { border-color:var(--accent); }
    .emoji-item img { width:100%; height:100%; object-fit:contain; }
    .emoji-item .del-emoji {
      position:absolute; top:0; right:0; background:#e53935; color:#fff;
      border-radius:0 10px 0 10px; padding:2px 6px; font-size:10px; cursor:pointer;
    }
    .pat-item {
      display:flex; align-items:center; justify-content:space-between; padding:6px 0;
    }
    .pat-item input { flex:1; margin-right:8px; }
    .toast {
      position:fixed; top:20%; left:50%; transform:translateX(-50%);
      background:var(--surface2); color:var(--text); padding:10px 20px; border-radius:20px;
      font-size:14px; z-index:300; box-shadow:var(--shadow); opacity:0; transition:opacity 0.3s;
      pointer-events:none;
    }
    .toast.show { opacity:1; }
    .heart-burst {
      position: fixed; z-index: 350; pointer-events: none;
      font-size: 24px; animation: heartFly 1s ease-out forwards;
    }
    @keyframes heartFly {
      0% { opacity:1; transform: translate(-50%, -50%) scale(0.5); }
      100% { opacity:0; transform: translate(-50%, -150%) scale(1.5); }
    }
    .gallery-grid {
      display: grid; grid-template-columns: repeat(auto-fill, minmax(100px,1fr));
      gap:8px; max-height:300px; overflow-y:auto;
    }
    .gallery-item {
      background: var(--surface2); padding:8px; border-radius:8px; font-size:13px;
      word-break: break-word; border:1px solid var(--border);
    }
  </style>
</head>
<body>
<div class="app" id="mainApp">
  <div class="header">
    <div class="avatar-wrap" id="dreamAvatarWrap">
      <div class="avatar" id="dreamAvatar">✦<span class="online-dot"></span></div>
    </div>
    <div class="info">
      <div class="name" id="dreamName">梦角</div>
      <div class="status-line" id="statusLine">
        <span id="weatherIcon">☀️</span>
        <span id="moodIcon">😊</span>
        <span id="statusText">在线</span>
      </div>
      <div class="anniversary-line" id="anniversaryLine" style="display:none;"></div>
    </div>
    <div class="actions">
      <button class="icon-btn" id="autoMsgBtn" title="让梦角主动发消息">💬</button>
      <button class="icon-btn" id="settingsBtn" title="设置">⚙️</button>
      <button class="icon-btn" id="envelopeBtn" title="信封投递">✉️</button>
    </div>
  </div>
  <div class="announcement-bar" id="announcementBar" style="display:none;">
    <span id="announcementText"></span>
    <button class="small-btn" id="closeAnnouncement">✕</button>
  </div>
  <div class="chat-area" id="chatArea"></div>
  <div class="quote-bar" id="quoteBar" style="display:none;">
    <span id="quoteText"></span>
    <button class="small-btn" id="cancelQuote">✕</button>
  </div>
  <div class="input-area">
    <button class="img-btn" id="imgSendBtn" title="发送图片/表情">🖼️</button>
    <textarea id="msgInput" rows="1" placeholder="正在输入..."></textarea>
    <button class="send-btn" id="sendBtn">➤</button>
  </div>
</div>

<!-- 设置浮层 -->
<div class="overlay" id="settingsOverlay">
  <div class="panel">
    <h3>设置</h3>
    <div class="tabs">
      <button class="tab-btn active" data-tab="basic">基础</button>
      <button class="tab-btn" data-tab="cards">字卡</button>
      <button class="tab-btn" data-tab="emoji">表情</button>
      <button class="tab-btn" data-tab="pat">拍一拍</button>
      <button class="tab-btn" data-tab="advanced">高级</button>
    </div>
    <div id="tabBasic">
      <div class="setting-row"><label>梦角名字</label><input id="setName" placeholder="梦角"></div>
      <div class="setting-row"><label>头像</label><input type="file" id="setAvatar" accept="image/*"></div>
      <div class="setting-row"><label>聊天背景</label><input type="file" id="setBg" accept="image/*"></div>
      <div class="setting-row"><label>回复延迟(秒)</label><input id="setDelayMin" type="number" value="1"> - <input id="setDelayMax" type="number" value="3"></div>
      <div class="setting-row"><label>每次回复条数</label><input id="setReplyCount" type="number" value="1" min="1" max="5"></div>
      <div class="setting-row"><label>主动发消息(分钟)</label><input id="setAutoInterval" type="number" value="0"></div>
      <div class="setting-row"><label>回复时表情概率(%)</label><input id="setEmojiProb" type="number" value="20" min="0" max="100"></div>
      <button class="btn btn-primary" id="saveBasic">保存设置</button>
    </div>
    <div id="tabCards" style="display:none;">
      <div class="setting-row"><input id="newCard" placeholder="新字卡"><button class="btn btn-secondary" id="addCard">添加</button></div>
      <div class="setting-row"><input id="newGroup" placeholder="新分组"><button class="btn btn-secondary" id="addGroup">创建分组</button></div>
      <div id="cardList" style="max-height:250px; overflow-y:auto;"></div>
      <button class="btn btn-primary" id="viewGallery">字卡画廊</button>
      <button class="btn btn-primary" id="importJsonBtn">导入 JSON</button>
      <button class="btn btn-secondary" id="exportJsonBtn">导出 JSON</button>
    </div>
    <div id="tabEmoji" style="display:none;">
      <div class="setting-row"><input type="file" id="emojiUpload" accept="image/*"><button class="btn btn-secondary" id="addEmojiBtn">添加表情</button></div>
      <div class="emoji-grid" id="emojiGrid"></div>
    </div>
    <div id="tabPat" style="display:none;">
      <div class="setting-row"><input id="newPat" placeholder="新拍一拍文案"><button class="btn btn-secondary" id="addPat">添加</button></div>
      <div id="patList"></div>
    </div>
    <div id="tabAdvanced" style="display:none;">
      <div class="setting-row"><label>天气</label><select id="setWeather">
        <option value="☀️晴朗">☀️晴朗</option><option value="⛅多云">⛅多云</option><option value="🌧小雨">🌧小雨</option><option value="🌈彩虹">🌈彩虹</option>
      </select></div>
      <div class="setting-row"><label>心情</label><select id="setMood">
        <option value="😊开心">😊开心</option><option value="😔思念">😔思念</option><option value="😴疲惫">😴疲惫</option><option value="🔥热情">🔥热情</option>
      </select></div>
      <div class="setting-row"><label>纪念日</label><input id="setAnniversary" type="date"></div>
      <div class="setting-row"><label>公告列表(一行一条)</label><textarea id="setAnnouncements" rows="3" style="width:100%"></textarea></div>
      <div class="setting-row"><label>状态文案(一行一条)</label><textarea id="setStatusTexts" rows="3" style="width:100%"></textarea></div>
      <div class="setting-row"><label>正在输入文案(一行一条)</label><textarea id="setTypingTexts" rows="3" style="width:100%"></textarea></div>
      <button class="btn btn-primary" id="saveAdvanced">保存高级设置</button>
    </div>
    <button class="btn btn-secondary" id="closeSettings" style="margin-top:16px; width:100%;">关闭</button>
  </div>
</div>

<!-- 字卡画廊浮层 -->
<div class="overlay" id="galleryOverlay">
  <div class="panel">
    <h3>字卡画廊</h3>
    <div class="setting-row"><select id="galleryGroupFilter"><option value="all">全部</option></select></div>
    <div class="gallery-grid" id="galleryGrid"></div>
    <button class="btn btn-secondary" id="closeGallery" style="margin-top:16px; width:100%;">关闭</button>
  </div>
</div>

<div class="toast" id="patToast"></div>
<input type="file" id="hiddenImgInput" accept="image/*" style="display:none;">

<script>
  const defaultData = {
    dreamName: "梦角", avatar: "", bg: "",
    delayMin: 1, delayMax: 3, replyCount: 1, autoInterval: 0,
    emojiProbability: 20,
    weather: "☀️晴朗", mood: "😊开心", anniversary: null,
    announcements: ["欢迎来到梦角的世界", "今天也要开心哦"],
    statusTexts: ["在线", "发呆中", "听音乐"],
    typingTexts: ["梦角正在选卡…", "梦角正在组织语言…", "梦角正在传送思念…"],
    replies: ["今天也要元气满满 ✦","我听见了，你的心声。","无论多远，我们的心始终相连。"],
    groups: [{ name:"默认", items:["今天也要元气满满 ✦","我听见了，你的心声。","无论多远，我们的心始终相连。"] }],
    patTexts: ["你拍了拍「梦角」"],
    introMessages: ["✦ 我们的故事，始于此刻 ✦","说点什么，让对话开始吧"],
    emojis: [],
    letterReplies: ["收到你的来信了。","你的信我已经读了好多遍。"]
  };

  function loadData() {
    try {
      const saved = localStorage.getItem('dreamCornerData');
      return saved ? JSON.parse(saved) : JSON.parse(JSON.stringify(defaultData));
    } catch(e) { return JSON.parse(JSON.stringify(defaultData)); }
  }
  let data = loadData();
  函数 saveData() { localStorage.setItem('dreamCornerData', JSON.stringify(data)); }

  const $ = id => document.getElementById(id);
  let chatMessages = [];
  let replyQuote = null;

  函数 applyBg() { chatArea.style.backgroundImage = data.bg ? `url(${data.bg})` : ''; }
  函数 applyAvatar() { dreamAvatar.innerHTML = data.avatar ? `<img src="${data.avatar}">` : '✦'; }

  函数 updateStatusLine() {
    document.getElementById('weatherIcon').textContent = data.weather ? data.weather.slice(0,2) : '☀️';
    document.getElementById('moodIcon').textContent = data.mood ? data.mood.slice(0,2) : '😊';
    const st = data.statusTexts.length ? data.statusTexts[Math.floor(Math.random()*data.statusTexts.length)] : '在线';
    document.getElementById('statusText').textContent = st;
  }

  function updateAnniversary() {
    const line = document.getElementById('anniversaryLine');
    if (data.anniversary) {
      const start = new Date(data.anniversary);
      const today = new Date(); today.setHours(0,0,0,0);
      const diff = Math.floor((today - start) / (1000*60*60*24));
      if (diff >= 0) {
        line.style.display = 'block';
        line.textContent = `💞 我们相伴了 ${diff} 天`;
      } 其他 line.style.display = 'none';
    } 其他 line.style.display = 'none';
  }

  function updateAnnouncement() {
    const bar = document.getElementById('announcementBar');
    if (data.announcements.length === 0) { bar.style.display = 'none'; return; }
    const todayStr = new Date().toDateString();
    const lastDate = localStorage.getItem('lastAnnounceDate');
    let index;
    if (lastDate === todayStr) {
      index = parseInt(localStorage.getItem('lastAnnounceIndex') || '0');
    } else {
      index = Math.floor(Math.random() * data.announcements.length);
      localStorage.setItem('lastAnnounceDate', todayStr);
      localStorage.setItem('lastAnnounceIndex', index);
    }
    document.getElementById('announcementText').textContent = '📢 ' + data.announcements[index];
    bar.style.display = 'flex';
  }

  function refreshUI() {
    document.getElementById('dreamName').textContent = data.dreamName;
    applyAvatar(); applyBg();
    updateStatusLine();
    updateAnniversary();
    updateAnnouncement();
    loadChatMessages();
  }

  function initChatMessages() {
    let intros = data.introMessages.length >=2 ? [...data.introMessages] : [...data.introMessages,"✦ 我们的故事，始于此刻 ✦"];
    intros.sort(()=>Math.random()-0.5);
    chatMessages = intros.slice(0,2).map(t=>({type:'text', text:t, me:false, time:Date.now()}));
  }

  function renderMessage(m) {
    const div = document.createElement('div');
    div.className = 'msg ' + (m.me ? 'me' : 'other');
    if (m.quote) div.innerHTML += `<div class="quote">${m.quote}</div>`;
    if (m.type === 'image') div.innerHTML += `<img src="${m.text}" style="max-width:180px;">`;
    else div.textContent = m.text;
    const timeStr = new Date(m.time).toLocaleTimeString([],{hour:'2-digit',minute:'2-digit'});
    div.innerHTML += `<div class="time">${timeStr}</div>`;
    div.addEventListener('click', ()=>{ if (!m.me && m.text) quoteReply(m.text); });
    chatArea.appendChild(div);
  }

  function loadChatMessages() {
    chatArea.innerHTML = '';
    chatMessages.forEach(m => renderMessage(m));
    chatArea.scrollTop = chatArea.scrollHeight;
  }

  function quoteReply(text) {
    replyQuote = text;
    quoteBar.style.display = 'flex';
    quoteText.textContent = text.length>20 ? text.slice(0,20)+'…' : text;
    msgInput.focus();
  }

  function addMessage(type, content, isMe, quote=null) {
    const msg = { type, text: content, me: isMe, time: Date.now() };
    if (quote) msg.quote = quote;
    chatMessages.push(msg);
    renderMessage(msg);
    chatArea.scrollTop = chatArea.scrollHeight;
  }

  function getRandomTypingText() {
    if (data.typingTexts.length) return data.typingTexts[Math.floor(Math.random()*data.typingTexts.length)];
    return "梦角正在输入…";
  }

  function showTyping() {
    removeTyping();
    const div = document.createElement('div'); div.className = 'typing-indicator'; div.id = 'typingIndicator';
    div.innerHTML = `${getRandomTypingText()} <span class="typing-dots"><span></span><span></span><span></span></span>`;
    chatArea.appendChild(div);
    chatArea.scrollTop = chatArea.scrollHeight;
  }

  function removeTyping() {
    const el = document.getElementById('typingIndicator'); if (el) el.remove();
  }

  function getRandomTextReply() {
    let all = []; data.groups.forEach(g=> all.push(...g.items));
    if (all.length===0) return "（无字卡）";
    return all[Math.floor(Math.random()*all.length)];
  }

  function getRandomEmoji() {
    if (data.emojis.length===0) return null;
    return data.emojis[Math.floor(Math.random()*data.emojis.length)];
  }

  function generateBotReplies(count) {
    const reps = [];
    for (let i=0;i<count;i++) {
      if (data.emojis.length && Math.random()*100 < data.emojiProbability) {
        const e = getRandomEmoji(); if (e) reps.push({type:'image', content:e});
      } else reps.push({type:'text', content: getRandomTextReply()});
    }
    if (reps.length===0) reps.push({type:'text', content:getRandomTextReply()});
    return reps;
  }

  function sendBotRepliesSequentially(reps) {
    reps.forEach((r,i)=> setTimeout(()=> addMessage(r.type, r.content, false), i*600));
  }

  function handleUserMessage(text) {
    if (!text) return;
    addMessage('text', text, true, replyQuote);
    replyQuote = null; quoteBar.style.display = 'none'; msgInput.value = '';
    showTyping();
    const delay = (data.delayMin + Math.random()*(data.delayMax-data.delayMin))*1000;
    setTimeout(()=>{
      removeTyping();
      sendBotRepliesSequentially(generateBotReplies(data.replyCount||1));
    }, delay);
  }

  function autoMessage() {
    sendBotRepliesSequentially(generateBotReplies(data.replyCount||1));
  }

  let autoTimer;
  function setupAutoTimer() {
    if (autoTimer) clearInterval(autoTimer);
    if (data.autoInterval>0) autoTimer = setInterval(autoMessage, data.autoInterval*60000);
  }

  function randomPat() {
    return data.patTexts.length ? data.patTexts[Math.floor(Math.random()*data.patTexts.length)] : "拍了拍";
  }

  function sendImageFile(file) {
    const reader = new FileReader();
    reader.onload = e=>{
      addMessage('image', e.target.result, true);
      showTyping();
      const delay = (data.delayMin + Math.random()*(data.delayMax-data.delayMin))*1000;
      setTimeout(()=>{ removeTyping(); sendBotRepliesSequentially(generateBotReplies(data.replyCount||1)); }, delay);
    };
    reader.readAsDataURL(file);
  }

  // 拍一拍特效
  function doPat() {
    const avatar = document.getElementById('dreamAvatar');
    avatar.classList.add('shake'); setTimeout(()=> avatar.classList.remove('shake'), 400);
    const heart = document.createElement('div'); heart.className = 'heart-burst'; heart.textContent = '❤️';
    const rect = avatar.getBoundingClientRect();
    heart.style.left = rect.left + rect.width/2 + 'px';
    heart.style.top = rect.top + rect.height/2 + 'px';
    document.body.appendChild(heart);
    setTimeout(()=> heart.remove(), 1000);
    patToast.textContent = randomPat(); patToast.classList.add('show');
    setTimeout(()=> patToast.classList.remove('show'), 1500);
  }

  // 绑定事件
  document.getElementById('sendBtn').addEventListener('click', ()=> handleUserMessage(msgInput.value));
  msgInput.addEventListener('keydown', e=>{ if (e.key==='Enter'&&!e.shiftKey){ e.preventDefault(); handleUserMessage(msgInput.value); } });
  document.getElementById('dreamAvatarWrap').addEventListener('click', doPat);
  document.getElementById('imgSendBtn').addEventListener('click', ()=> document.getElementById('hiddenImgInput').click());
  document.getElementById('hiddenImgInput').addEventListener('change', e=>{ if(e.target.files[0]) sendImageFile(e.target.files[0]); e.target.value=''; });
  document.getElementById('autoMsgBtn').addEventListener('click', autoMessage);
  document.getElementById('settingsBtn').addEventListener('click', ()=>{
    document.getElementById('settingsOverlay').classList.add('active');
    refreshSettingsPanel();
    document.querySelector('.tab-btn.active').click();
  });
  document.getElementById('closeSettings').addEventListener('click', ()=> document.getElementById('settingsOverlay').classList.remove('active'));
  document.getElementById('cancelQuote').addEventListener('click', ()=>{ replyQuote=null; quoteBar.style.display='none'; });

  function refreshSettingsPanel() {
    document.getElementById('setName').value = data.dreamName;
    document.getElementById('setDelayMin').value = data.delayMin;
    document.getElementById('setDelayMax').value = data.delayMax;
    document.getElementById('setReplyCount').value = data.replyCount;
    document.getElementById('setAutoInterval').value = data.autoInterval;
    document.getElementById('setEmojiProb').value = data.emojiProbability;
    document.getElementById('setWeather').value = data.weather;
    document.getElementById('setMood').value = data.mood;
    document.getElementById('setAnniversary').value = data.anniversary || '';
    document.getElementById('setAnnouncements').value = data.announcements.join('\n');
    document.getElementById('setStatusTexts').value = data.statusTexts.join('\n');
    document.getElementById('setTypingTexts').value = data.typingTexts.join('\n');
    renderCardList(); renderEmojiGrid(); renderPatList();
  }

  function saveBasic() {
    data.dreamName = document.getElementById('setName').value || '梦角';
    data.delayMin = parseFloat(document.getElementById('setDelayMin').value)||1;
    data.delayMax = parseFloat(document.getElementById('setDelayMax').value)||3;
    data.replyCount = parseInt(document.getElementById('setReplyCount').value)||1;
    data.autoInterval = parseInt(document.getElementById('setAutoInterval').value)||0;
    data.emojiProbability = parseInt(document.getElementById('setEmojiProb').value)||0;
    saveData(); setupAutoTimer(); refreshUI();
    document.getElementById('settingsOverlay').classList.remove('active');
  }

  function saveAdvanced() {
    data.weather = document.getElementById('setWeather').value;
    data.mood = document.getElementById('setMood').value;
    data.anniversary = document.getElementById('setAnniversary').value || null;
    data.announcements = document.getElementById('setAnnouncements').value.split('\n').filter(l=>l.trim());
    data.statusTexts = document.getElementById('setStatusTexts').value.split('\n').filter(l=>l.trim());
    data.typingTexts = document.getElementById('setTypingTexts').value.split('\n').filter(l=>l.trim());
    saveData(); refreshUI();
    document.getElementById('settingsOverlay').classList.remove('active');
  }

  document.getElementById('saveBasic').addEventListener('click', saveBasic);
  document.getElementById('saveAdvanced').addEventListener('click', saveAdvanced);
  document.getElementById('setAvatar').addEventListener('change', e=>{
    const f=e.target.files[0]; if(!f)return; const r=new FileReader();
    r.onload=ev=>{ data.avatar=ev.target.result; saveData(); applyAvatar(); }; r.readAsDataURL(f);
  });
  document.getElementById('setBg').addEventListener('change', e=>{
    const f=e.target.files[0]; if(!f)return; const r=new FileReader();
    r.onload=ev=>{ data.bg=ev.target.result; saveData(); applyBg(); }; r.readAsDataURL(f);
  });

  // 字卡管理
  function renderCardList() {
    const c = document.getElementById('cardList'); c.innerHTML = '';
    data.groups.forEach((g,gi)=>{
      const d = document.createElement('div'); d.innerHTML = `<strong style="color:var(--accent)">${g.name}</strong> <button class="small-btn danger del-group" data-idx="${gi}">删组</button>`; c.appendChild(d);
      g.items.forEach((item,ii)=>{
        const row = document.createElement('div'); row.className='list-item';
        row.innerHTML = `<span>${item}</span><button class="small-btn danger del-card" data-g="${gi}" data-i="${ii}">✕</button>`; c.appendChild(row);
      });
      const addInp = document.createElement('input'); addInp.placeholder='添加字卡'; addInp.style.width='60%';
      const addBtn = document.createElement('button'); addBtn.textContent='+'; addBtn.className='small-btn';
      addBtn.addEventListener('click', ()=>{ if(addInp.value.trim()){ g.items.push(addInp.value.trim()); saveData(); renderCardList(); } });
      const wrap = document.createElement('div'); wrap.style.display='flex'; wrap.appendChild(addInp); wrap.appendChild(addBtn); c.appendChild(wrap);
    });
    document.querySelectorAll('.del-card').forEach(btn=>{
      btn.addEventListener('click', ()=>{ const g=parseInt(btn.dataset.g), i=parseInt(btn.dataset.i); data.groups[g].items.splice(i,1); saveData(); renderCardList(); });
    });
    document.querySelectorAll('.del-group').forEach(btn=>{
      btn.addEventListener('click', ()=>{ data.groups.splice(parseInt(btn.dataset.idx),1); saveData(); renderCardList(); });
    });
  }

  document.getElementById('addCard').addEventListener('click', ()=>{
    const v = document.getElementById('newCard').value.trim(); if(!v)return;
    if(data.groups.length===0) data.groups.push({name:'默认',items:[]});
    data.groups[0].items.push(v); saveData(); document.getElementById('newCard').value=''; renderCardList();
  });
  document.getElementById('addGroup').addEventListener('click', ()=>{
    const v = document.getElementById('newGroup').value.trim(); if(!v)return;
    data.groups.push({name:v,items:[]}); saveData(); document.getElementById('newGroup').value=''; renderCardList();
  });

  // 字卡画廊
  function openGallery() {
    const overlay = document.getElementById('galleryOverlay');
    overlay.classList.add('active');
    const sel = document.getElementById('galleryGroupFilter');
    sel.innerHTML = '<option value="all">全部</option>';
    data.groups.forEach((g,i)=> sel.innerHTML += `<option value="${i}">${g.name}</option>`);
    function renderGallery(filter) {
      const grid = document.getElementById('galleryGrid'); grid.innerHTML = '';
      let items = [];
      if (filter === 'all') data.groups.forEach(g=> items.push(...g.items));
      else items = data.groups[parseInt(filter)]?.items || [];
      items.forEach(text=> {
        const div = document.createElement('div'); div.className = 'gallery-item'; div.textContent = text;
        grid.appendChild(div);
      });
    }
    sel.addEventListener('change', ()=> renderGallery(sel.value));
    renderGallery('all');
  }

  document.getElementById('viewGallery').addEventListener('click', ()=>{
    document.getElementById('settingsOverlay').classList.remove('active');
    openGallery();
  });
  document.getElementById('closeGallery').addEventListener('click', ()=> document.getElementById('galleryOverlay').classList.remove('active'));

  // 表情管理
  function renderEmojiGrid() {
    const g = document.getElementById('emojiGrid'); g.innerHTML = '';
    data.emojis.forEach((s,i)=>{
      const d = document.createElement('div'); d.className='emoji-item';
      d.innerHTML = `<img src="${s}"><span class="del-emoji" data-idx="${i}">✕</span>`;
      d.querySelector('.del-emoji').addEventListener('click', e=>{ e.stopPropagation(); data.emojis.splice(i,1); saveData(); renderEmojiGrid(); });
      g.appendChild(d);
    });
  }
  document.getElementById('addEmojiBtn').addEventListener('click', ()=>{
    const f = document.getElementById('emojiUpload').files[0]; if(!f)return;
    const r = new FileReader(); r.onload=e=>{ data.emojis.push(e.target.result); saveData(); renderEmojiGrid(); }; r.readAsDataURL(f);
    document.getElementById('emojiUpload').value='';
  });

  // 拍一拍
  function renderPatList() {
    const l = document.getElementById('patList'); l.innerHTML = '';
    data.patTexts.forEach((t,i)=>{
      const row = document.createElement('div'); row.className='pat-item';
      row.innerHTML = `<input value="${t}" readonly><button class="small-btn danger" data-idx="${i}">删除</button>`;
      row.querySelector('button').addEventListener('click', ()=>{ data.patTexts.splice(i,1); saveData(); renderPatList(); });
      l.appendChild(row);
    });
  }
  document.getElementById('addPat').addEventListener('click', ()=>{
    const v = document.getElementById('newPat').value.trim(); if(!v)return;
    data.patTexts.push(v); saveData(); document.getElementById('newPat').value=''; renderPatList();
  });

  // JSON导入导出
  document.getElementById('importJsonBtn').addEventListener('click', ()=>{
    const inp = document.createElement('input'); inp.type='file'; inp.accept='.json';
    inp.addEventListener('change', e=>{
      const f = e.target.files[0]; if(!f)return; const r = new FileReader();
      r.onload = ev=>{
        try{
          const j = JSON.parse(ev.target.result);
          if(j.customReplies) data.replies=j.customReplies;
          if(j.customReplyGroups) data.groups=j.customReplyGroups.map(g=>({name:g.name,items:g.items}));
          if(j.customPokes) data.patTexts=j.customPokes;
          if(j.customStatuses) data.statusTexts=j.customStatuses;
          if(j.customIntros) data.introMessages=j.customIntros;
          if(j.customEmojis) data.emojis=j.customEmojis;
          if(j.weather) data.weather=j.weather;
          if(j.mood) data.mood=j.mood;
          if(j.anniversary) data.anniversary=j.anniversary;
          if(j.announcements) data.announcements=j.announcements;
          if(j.typingTexts) data.typingTexts=j.typingTexts;
          saveData(); refreshSettingsPanel(); alert('导入成功');
        }catch(ex){ alert('JSON格式错误'); }
      }; r.readAsText(f);
    }); inp.click();
  });
  document.getElementById('exportJsonBtn').addEventListener('click', ()=>{
    const exportData = {
      customReplies: data.replies, customReplyGroups: data.groups,
      customPokes: data.patTexts, customStatuses: data.statusTexts,
      customIntros: data.introMessages, customEmojis: data.emojis,
      weather: data.weather, mood: data.mood, anniversary: data.anniversary,
      announcements: data.announcements, typingTexts: data.typingTexts
    };
    const blob = new Blob([JSON.stringify(exportData,null,2)], {type:'application/json'});
    const a = document.createElement('a'); a.href = URL.createObjectURL(blob); a.download = '梦角字卡备份.json'; a.click();
  });

  // Tab切换
  document.querySelectorAll('.tab-btn').forEach(btn=>{
    btn.addEventListener('click', ()=>{
      document.querySelectorAll('.tab-btn').forEach(b=>b.classList.remove('active')); btn.classList.add('active');
      ['tabBasic','tabCards','tabEmoji','tabPat','tabAdvanced'].forEach(t=> document.getElementById(t).style.display='none');
      document.getElementById('tab'+btn.dataset.tab.charAt(0).toUpperCase()+btn.dataset.tab.slice(1)).style.display='block';
    });
  });

  // 关闭公告
  document.getElementById('closeAnnouncement').addEventListener('click', ()=>{
    document.getElementById('announcementBar').style.display = 'none';
  });

  // 启动
  (function init() {
    mainApp.style.display = 'flex';
    initChatMessages(); refreshUI(); setupAutoTimer();
  })();
</script>
</body>
</html>
